<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>小红书封面</title>
  <!-- 思源宋体 - 使用 Google Fonts API 加载完整简体中文字符集 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&display=swap&subset=chinese-simplified" rel="stylesheet">
  <style>
    /* 全局字体栈 - 与正文模板保持一致 */
    :root {
      --font-serif: "Noto Serif SC", "Source Han Serif SC", "Source Han Serif CN", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", serif;
    }
    :root {
      --bg: #fffef9;
      --text: #1a1a1a;
      --title-color: #1a1a1a;  /* 深黑色 - 最大对比度 */
      --highlight-color: #D4AF37;  /* 亮金色 - 浅色主题 */
      --accent: #2d7d9a;
      --accent-light: rgba(45, 125, 154, 0.1);
      --muted: #6b6b6b;
    }

    [data-theme="dark"] {
      --bg: #1a1a1a;
      --text: #e8e6e3;
      --title-color: #FFD700;  /* 亮金色 - 深色主题 */
      --highlight-color: rgba(255, 215, 0, 0.4);  /* 金色高亮 - 深色主题 */
      --accent: #5eb3d4;
      --accent-light: rgba(94, 179, 212, 0.15);
      --muted: #8a8783;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-serif);
      background: var(--bg);
      width: 675px;
      height: 1200px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      position: relative;
      overflow: hidden;
    }

    /* 背景装饰 - 延伸到整个封面 */
    .bg-decoration {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    /* 顶部装饰 - 首页不可见 (y: 0-150) */
    .top-decoration {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 140px;
      opacity: 0.05;
    }

    .top-circle {
      position: absolute;
      border-radius: 50%;
      background: var(--accent);
    }

    .top-circle:nth-child(1) {
      width: 200px;
      height: 200px;
      top: -80px;
      right: -50px;
    }

    /* 底部装饰 */
    .bottom-decoration {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 140px;
      opacity: 0.05;
    }

    .bottom-circle {
      position: absolute;
      border-radius: 50%;
      background: var(--accent);
    }

    .bottom-circle:nth-child(1) {
      width: 250px;
      height: 250px;
      bottom: -100px;
      left: -80px;
    }

    /* 核心内容区 - 3:4 展示区域 (y: 150-1050, 高度 900px) */
    .core-content {
      position: absolute;
      top: 150px;
      left: 0;
      width: 100%;
      height: 900px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      z-index: 1;
    }

    

    /* 主标题 - 左对齐 */
    .title-container {
      text-align: left;
      padding: 0 50px;
      position: relative;
    }

    .title {
      font-family: var(--font-serif);
      font-size: 100px;
      font-weight: 700;
      color: var(--title-color);
      line-height: 1.25;
      letter-spacing: 0.02em;
      text-shadow: 0 2px 8px rgba(0,0,0,0.15);
      position: relative;
      display: inline-block;
    }

    /* 标题高亮线 - 浅色用亮金色，深色用灰色 */
    .title::after {
      content: '';
      position: absolute;
      left: -4px;
      bottom: 8px;
      width: calc(100% + 8px);
      height: 12px;
      background: var(--highlight-color);
      border-radius: 3px;
      z-index: -1;
    }

    /* 分隔线 - 隐藏，已用高亮线替代 */
    .divider {
      display: none;
    }

    /* 滑动引导 */
    .swipe-hint {
      display: flex;
      margin-top: 40px;
      align-items: center;
      justify-content: center;
      width: 100%;
      gap: 12px;
      color: var(--muted);
      opacity: 0.6;
      font-size: 26px;
    }

    .swipe-hint.visible {
      display: flex;
    }

    .swipe-hint svg {
      width: 28px;
      height: 28px;
      animation: swipe 1.5s ease-in-out infinite;
    }

    @keyframes swipe {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(8px); }
    }

    /* 底部信息行 - 在 3:4 区域外 */
    .footer {
      position: absolute;
      bottom: 40px;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      padding: 0 40px;
      font-size: 15px;
      color: var(--muted);
      opacity: 0.6;
    }

    .footer-left {
      font-weight: 500;
    }

    .footer-right {
      font-weight: 400;
    }

    /* 开发调试用 - 取消注释可看到 3:4 区域边界 */
    /*
    .debug-frame {
      position: absolute;
      top: 150px;
      left: 0;
      width: 100%;
      height: 900px;
      border: 2px dashed red;
      z-index: 100;
      pointer-events: none;
    }
    */
  </style>
</head>
<body>
  <!-- 背景装饰 -->
  <div class="bg-decoration">
    <!-- 顶部装饰 -->
    <div class="top-decoration">
      <div class="top-circle"></div>
    </div>
    <!-- 底部装饰 -->
    <div class="bottom-decoration">
      <div class="bottom-circle"></div>
    </div>
  </div>

  

  <!-- 核心内容 - 在 3:4 展示区域内 -->
  <div class="core-content">
    <div class="title-container">
      <h1 class="title" id="title">标题占位文字</h1>
    </div>
    <div class="divider"></div>
    <!-- 滑动引导 - 首页不显示 -->
    <div class="swipe-hint" id="swipeHint">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <span>向右滑动查看正文</span>
    </div>
  </div>

  <!-- 底部信息 - 在 3:4 区域外 -->
  <div class="footer">
    <span class="footer-left" id="customText">@豆包</span>
    <span class="footer-right" id="dateText">2026年3月1日</span>
  </div>

  <!-- 调试用 - 取消注释可看到 3:4 区域 -->
  <!-- <div class="debug-frame"></div> -->
</body>
</html>